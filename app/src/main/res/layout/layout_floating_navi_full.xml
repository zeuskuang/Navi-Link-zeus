<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/window_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <FrameLayout
        android:id="@+id/root_layout"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        android:background="@drawable/bg_floating_dark">
        <LinearLayout
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingBottom="5dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="70dp">
        <RelativeLayout
            android:layout_centerVertical="true"
            android:background="@drawable/ic_speed"
            android:layout_width="50dp"
            android:layout_height="50dp">
            <TextView
                android:textColor="#FFFFFF"
                android:layout_centerInParent="true"
                android:id="@+id/tv_full_speed"
                android:text="0"
                android:textStyle="bold"
                android:textSize="24sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tv_full_speed_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="3dp"
                android:text="km/h"
                android:textColor="#BBFFFFFF"
                android:textSize="10sp"/>
        </RelativeLayout>
        <com.navi.link.TrafficLightView
            android:id="@+id/ll_traffic_light_group"
            android:visibility="gone"
            android:layout_centerInParent="true"
            android:layout_width="wrap_content"
            android:layout_height="50dp"/>
        <TextView
            android:layout_alignParentEnd="true"
            android:background="@drawable/camera_shape"
            android:layout_centerVertical="true"
            android:id="@+id/tv_full_speed_limit"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="0"
            android:textColor="#1a1a1a"
            android:textSize="24sp" />
    </RelativeLayout>
            <!-- 车道线组件 -->
            <com.navi.link.LaneLineView
                android:id="@+id/lane_line_view_full"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:visibility="gone" />
<LinearLayout
    android:layout_marginTop="15dp"
    android:gravity="center_vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:id="@+id/tv_full_label_current"
        android:textSize="14sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF0099FF"
        android:text="当前："/>

    <TextView
        android:id="@+id/tv_full_cur_road_name"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="当前道路名称"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_alignParentBottom="true"
        android:id="@+id/tv_full_direction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="朝向 南"
        android:textColor="#88FFFFFF"
        android:textSize="16sp" />
</LinearLayout>


        <androidx.cardview.widget.CardView
            android:id="@+id/cv_full_middle"
            android:layout_marginTop="15dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            app:cardBackgroundColor="#FF0099FF"
            app:cardCornerRadius="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_action_icon_full"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="5dp"
                android:scaleType="centerInside"
                android:src="@mipmap/light_straight"/>
            <TextView
                android:id="@+id/tv_distance_num_full"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:includeFontPadding="false"
                android:text="283"
                android:textColor="#FFFFFF"
                android:textSize="35sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_distance_unit_full"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginTop="4dp"
                android:text="米进入"
                android:textColor="#BBFFFFFF"
                android:textSize="14sp"/>

        </LinearLayout>
            <TextView
                android:layout_marginBottom="5dp"
                android:layout_gravity="bottom"
                android:id="@+id/tv_road_name_min"
                android:layout_width="match_parent"
                android:gravity="center"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:maxWidth="200dp"
                android:text="居里夫人大道"
                android:textColor="#FFFFFF"
                android:textSize="25sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_marginTop="15dp"
                    android:id="@+id/tv_summary_full"
                    android:layout_width="match_parent"
                    android:gravity="center"
                    android:layout_height="wrap_content"
                    android:text="1.1公里 · 4分钟"
                    android:textColor="#E0E0E0"
                    android:textSize="20sp"
                    android:textStyle="bold" />


                <TextView
                    android:layout_marginTop="10dp"
                    android:id="@+id/tv_eta_full"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="18:06到"
                    android:textColor="#E0E0E0"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            <LinearLayout
                android:layout_marginTop="15dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tv_full_label_end"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF0099FF"
                android:text="终点："/>

            <TextView
                android:id="@+id/tv_full_end_poi_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="终点名称"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
         <LinearLayout

             android:gravity="center_vertical"
             android:layout_width="match_parent"
             android:layout_height="70dp">
             <com.navi.link.CameraWarningView
                 android:id="@+id/tv_full_camera_dist"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content" />
            <LinearLayout
                android:layout_width="0dp"
                android:gravity="center"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <View

                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:background="#E0E0E0"/>
            </LinearLayout>
             <ImageView
                 android:padding="10dp"
                 android:background="@drawable/camera_shape"
                 android:src="@mipmap/light"
                 android:layout_width="40dp"
                 android:layout_height="40dp"/>
             <TextView
                 android:id="@+id/tv_full_light_count"
                 android:layout_marginStart="10dp"
                 android:textColor="#ffffff"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:text="--"
                 android:textStyle="bold"
                 android:textSize="18sp"/>
         </LinearLayout>

         <com.navi.link.TmcProgressBar
             android:id="@+id/tmc_progress_bar_full"
             android:layout_width="match_parent"
             android:layout_height="wrap_content" />
        </LinearLayout>
</FrameLayout>
</FrameLayout>

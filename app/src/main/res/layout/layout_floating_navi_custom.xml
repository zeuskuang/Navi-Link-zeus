<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/window_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false">

    <FrameLayout
        android:id="@+id/root_layout"
        android:background="@drawable/bg_main_navigation_box"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- 方向 -->
        <TextView
            android:id="@+id/custom_navi_direction"
            android:textColor="#FF0099FF"
            android:textSize="25sp"
            android:textStyle="bold"
            android:text="北"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="6dp" />

        <!-- 速度 + 单位 -->
        <LinearLayout
            android:id="@+id/custom_navi_speed_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginStart="8dp"
            android:layout_marginTop="30dp">

            <TextView
                android:id="@+id/tv_navi_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="#FF0099FF"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_navi_speed_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginBottom="0dp"
                android:text="km/h"
                android:textColor="#BBFFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 仪表速度（与数字速度二选一） -->
        <com.navi.link.SpeedometerView
            android:id="@+id/navi_speed_gauge"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- 转向信息组: 转向图标 + 距离 -->
        <LinearLayout
            android:id="@+id/custom_navi_turn_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="100dp"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/iv_navi_turn_icon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:scaleType="centerInside"
                android:src="@mipmap/light_straight" />

            <TextView
                android:id="@+id/tv_navi_distance_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="283"
                android:textColor="#FFFFFF"
                android:textSize="35sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp" />

            <TextView
                android:id="@+id/tv_navi_distance_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginBottom="0dp"
                android:text="米"
                android:textColor="#BBFFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 路名 -->
        <TextView
            android:id="@+id/custom_navi_roadname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="100dp"
            android:layout_marginTop="55dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:maxEms="6"
            android:text="居里夫人大道"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <!-- 红绿灯个数 -->
        <TextView
            android:id="@+id/custom_navi_lightcount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="280dp"
            android:layout_marginTop="8dp"
            android:text="🚦3个"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:visibility="visible" />

        <!-- 车道线 -->
        <com.navi.link.LaneLineView
            android:id="@+id/custom_navi_lane"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginStart="200dp"
            android:layout_marginTop="6dp"
            android:visibility="visible" />

        <!-- 红绿灯 -->
        <com.navi.link.TrafficLightView
            android:id="@+id/custom_navi_trafficlight"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginStart="280dp"
            android:layout_marginTop="40dp"
            android:visibility="visible" />

        <!-- 摄像头 -->
        <com.navi.link.CameraWarningView
            android:id="@+id/custom_navi_camera"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginStart="320dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_traffic_light_capsule"
            android:paddingStart="4dp"
            android:paddingEnd="10dp"
            android:visibility="visible" />

        <!-- TMC路况进度条 -->
        <com.navi.link.TmcProgressBar
            android:id="@+id/custom_navi_tmc"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="100dp"
            android:layout_marginTop="80dp"
            android:visibility="visible" />

    </FrameLayout>
</FrameLayout>

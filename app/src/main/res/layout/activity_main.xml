<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FF121212"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:padding="24dp"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="悬浮窗配置"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/ll_startup_container"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <TextView
                android:textSize="13sp"
                android:textColor="#FFAAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="启动方式" />

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_service_only"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    app:cardBackgroundColor="#FF1E1E1E"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FF444444"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rb_service_only"
                            android:textSize="14sp"
                            android:textColor="#FFFFFFFF"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="只启动服务"
                            android:buttonTint="#FF4FC3F7" />

                        <TextView
                            android:textSize="11sp"
                            android:textColor="#FF888888"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="点击图标直接启动服务" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_normal_start"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="0dp"
                    android:layout_marginEnd="12dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FF1E1E1E"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FF444444"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rb_normal_start"
                            android:textSize="14sp"
                            android:textColor="#FFFFFFFF"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="正常打开"
                            android:buttonTint="#FF4FC3F7" />

                        <TextView
                            android:textSize="11sp"
                            android:textColor="#FF888888"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="点击图标打开配置页面" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
<!--                <com.google.android.material.button.MaterialButton-->
<!--                    android:id="@+id/btn_go_home"-->
<!--                   -->
<!--                    android:text="回到桌面"-->
<!--                    android:textSize="16sp"-->
<!--                    android:textColor="#FFFFFFFF"-->
<!--                    android:layout_width="0dp"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_weight="1"-->
<!--                    app:cardBackgroundColor="#FF1E1E1E"-->
<!--                    app:cardCornerRadius="10dp"-->
<!--                    app:cardElevation="0dp"-->
<!--                    app:strokeColor="#FF444444"-->
<!--                    app:strokeWidth="1dp" />-->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_go_home"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FF1E1E1E"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:id="@+id/btn_go_home"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="回到桌面"
                        android:textColor="#ffffff"
                        android:textSize="25sp"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_style_container"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_startup_container">

            <TextView
                android:textSize="13sp"
                android:textColor="#FFAAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="悬浮窗样式" />

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_normal"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#FF1E1E1E"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FF444444"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rb_normal"
                            android:textSize="14sp"
                            android:textColor="#FFFFFFFF"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="常规"
                            android:buttonTint="#FF4FC3F7" />

                        <TextView
                            android:textSize="11sp"
                            android:textColor="#FF888888"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="完整导航信息" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_minimal"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#FF1E1E1E"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FF444444"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rb_minimal"
                            android:textSize="14sp"
                            android:textColor="#FFFFFFFF"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="灵动岛"
                            android:buttonTint="#FF4FC3F7" />

                        <TextView
                            android:textSize="11sp"
                            android:textColor="#FF888888"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="精简灵动岛风格" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_full"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FF1E1E1E"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FF444444"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rb_full"
                            android:textSize="14sp"
                            android:textColor="#FFFFFFFF"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="全数据"
                            android:buttonTint="#FF4FC3F7" />

                        <TextView
                            android:textSize="11sp"
                            android:textColor="#FF888888"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="竖版全导航信息" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_scale_label"
            android:textSize="16sp"
            android:textColor="#FFAAAAAA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="悬浮窗缩放"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_style_container" />

        <TextView
            android:id="@+id/tv_scale_value"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FF4FC3F7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.0x"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_scale_label" />

        <SeekBar
            android:id="@+id/sb_scale"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:max="15"
            android:progress="5"
            android:progressTint="#FF4FC3F7"
            android:thumbTint="#FF4FC3F7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_scale_label" />

        <LinearLayout
            android:id="@+id/layout_scale_range"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sb_scale">

            <TextView
                android:textSize="12sp"
                android:textColor="#FF666666"
                android:gravity="start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0.5x" />

            <TextView
                android:textSize="12sp"
                android:textColor="#FF666666"
                android:gravity="end"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2.0x" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_theme_label"
            android:textSize="16sp"
            android:textColor="#FFAAAAAA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="主色调"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_scale_range" />

        <LinearLayout
            android:id="@+id/ll_theme_colors"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_theme_label" />

        <TextView
            android:id="@+id/tv_bg_label"
            android:textSize="16sp"
            android:textColor="#FFAAAAAA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="背景模式"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_theme_colors" />

        <LinearLayout
            android:id="@+id/ll_bg_modes"
            android:orientation="horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_bg_label">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_bg_dark"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="#FF1E1E1E"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="#FF444444"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rb_bg_dark"
                        android:textSize="14sp"
                        android:textColor="#FFFFFFFF"
                        android:clickable="false"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="深色"
                        android:buttonTint="#FF4FC3F7" />

                    <TextView
                        android:textSize="11sp"
                        android:textColor="#FF888888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:text="原有深色背景" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_bg_semi"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="#FF1E1E1E"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="#FF444444"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rb_bg_semi"
                        android:textSize="14sp"
                        android:textColor="#FFFFFFFF"
                        android:clickable="false"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="半透明"
                        android:buttonTint="#FF4FC3F7" />

                    <TextView
                        android:textSize="11sp"
                        android:textColor="#FF888888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:text="50%透明背景" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_bg_transparent"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="#FF1E1E1E"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="#FF444444"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rb_bg_transparent"
                        android:textSize="14sp"
                        android:textColor="#FFFFFFFF"
                        android:clickable="false"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="全透明"
                        android:buttonTint="#FF4FC3F7" />

                    <TextView
                        android:textSize="11sp"
                        android:textColor="#FF888888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:text="文字跟随昼夜" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:textSize="14sp"
            android:textColor="#FF888888"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_bg_modes" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>